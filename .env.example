# CCC Environment Variables
# Copy this file to .env.local and fill in your values

# ── Supabase ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
USE_SUPABASE_FILES=true

# ── Anthropic API (for planning phase AI questions) ──────────────
ANTHROPIC_API_KEY=

# ── Webhook security (optional, for agent completion callbacks) ──
WEBHOOK_SECRET=

# ── Agent execution ──────────────────────────────────────────────
# Override agent model selection (leave empty to use agent config)
CCC_FORCE_MODEL=
